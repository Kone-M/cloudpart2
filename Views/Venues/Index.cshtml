@model IEnumerable<VenueBookingSystem.Models.Venue>

@{
    ViewData["Title"] = "Venues";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-building"></i> Venues</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Venue
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.VenueName" style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="bg-light text-center py-5">
                            <i class="bi bi-building fs-1 text-secondary"></i>
                            <p class="text-muted">No image</p>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@item.VenueName</h5>
                        <p class="card-text">
                            <i class="bi bi-geo-alt"></i> @item.Location<br />
                            <i class="bi bi-people"></i> Capacity: @item.Capacity<br />
                            <i class="bi bi-calendar"></i> Created: @item.CreatedAt.ToString("yyyy-MM-dd")
                        </p>
                        <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                    <div class="card-footer bg-white">
                        <a asp-action="Edit" asp-route-id="@item.VenueID" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.VenueID" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>