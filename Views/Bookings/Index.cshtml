@model IEnumerable<VenueBookingSystem.Models.BookingViewModel>

@{
    ViewData["Title"] = "Manage Bookings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="bi bi-calendar-check"></i>
            Booking Management
        </h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> New Booking
        </a>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle-fill"></i> @TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search Bar -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search text-primary"></i>
                        </span>
                        <input type="text"
                               name="searchTerm"
                               class="form-control form-control-lg"
                               placeholder="Search by Booking ID, Event Name, Venue Name, or Organizer..."
                               value="@ViewBag.SearchTerm" />
                        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Clear
                            </a>
                        }
                    </div>
                    @if (ViewBag.SearchCount != null && (int)ViewBag.SearchCount > 0)
                    {
                        <small class="text-muted mt-2 d-block">
                            Found @ViewBag.SearchCount booking(s) matching "@ViewBag.SearchTerm"
                        </small>
                    }
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Bookings Table -->
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-table"></i> All Bookings</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Booking ID</th>
                            <th>Display Title</th>
                            <th>Booking Date & Time</th>
                            <th>Event Date</th>
                            <th>Venue</th>
                            <th>Location</th>
                            <th>Capacity</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5">
                                    <div class="alert alert-warning mb-0">
                                        <i class="bi bi-inbox fs-1 d-block"></i>
                                        <p class="mt-2">No bookings found.</p>
                                        <a asp-action="Create" class="btn btn-primary btn-sm">Create your first booking</a>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary fs-6">#@item.BookingID</span>
                                    </td>
                                    <td>
                                        <strong>@item.DisplayTitle</strong>
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <br />
                                            <small class="text-muted">@(item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)</small>
                                        }
                                    </td>
                                    <td>
                                        <i class="bi bi-clock"></i>
                                        @item.BookingDate.ToString("yyyy-MM-dd HH:mm")
                                    </td>
                                    <td>
                                        <i class="bi bi-calendar-event"></i>
                                        @item.EventDate.ToString("yyyy-MM-dd HH:mm")
                                        <br />
                                        <small class="text-muted">(@item.DurationHours hrs)</small>
                                    </td>
                                    <td>@item.VenueName</td>
                                    <td>@item.Location</td>
                                    <td>
                                        <span class="badge bg-info">@item.Capacity</span>
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = item.Status switch
                                            {
                                                "Confirmed" => "success",
                                                "Cancelled" => "danger",
                                                "Completed" => "secondary",
                                                _ => "warning"
                                            };
                                            var statusIcon = item.Status switch
                                            {
                                                "Confirmed" => "check-circle",
                                                "Cancelled" => "x-circle",
                                                "Completed" => "check2-circle",
                                                _ => "question-circle"
                                            };
                                        }
                                        <span class="badge bg-@statusClass">
                                            <i class="bi bi-@statusIcon"></i> @item.Status
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-action="Delete" asp-route-id="@item.BookingID"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('Are you sure you want to cancel this booking?')">
                                            <i class="bi bi-x-circle"></i> Cancel
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}